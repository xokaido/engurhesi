{
  "name": "engurhesi",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 5199",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply engurhesi --local",
    "db:seed:local": "node scripts/seed.mjs && wrangler d1 execute engurhesi --local --file scripts/seed.generated.sql && sh scripts/seed-media-upload.sh",
    "db:migrate:preview": "wrangler d1 migrations apply engurhesi --remote --env preview",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "deploy:production": "npm run build && wrangler deploy --env production"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250704.0",
    "@sveltejs/adapter-cloudflare": "^7.0.5",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@types/node": "^22.15.30",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.34.7",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "drizzle-orm": "^0.44.2",
    "prosemirror-model": "^1.25.1",
    "zod": "^3.25.56"
  }
}
